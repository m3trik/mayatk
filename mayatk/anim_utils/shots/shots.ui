          </size>
         </property>
         <property name="toolTip">
          <string>How to generate shot boundaries from animation.
• Auto-Detect – scan scene animation and cluster by gap.
• All Keys – every selected key is a boundary (contiguous shots).
• Skip Zero-Value – ignore keys with value 0.
• Zero = Shot End – non-zero keys start shots, zero keys end them.</string>
         </property>
         <item>
          <property name="text">
           <string>Auto-Detect</string>
          </property>
         </item>
         <item>
          <property name="text">
           <string>All Keys</string>
          </property>
         </item>
         <item>
          <property name="text">
           <string>Skip Zero-Value</string>
          </property>
         </item>
         <item>
          <property name="text">
           <string>Zero = Shot End</string>
          </property>
         </item>
        </widget>
       </item>
       <item>
        <widget class="SpinBox" name="spn_detection">
         <property name="minimumSize">
          <size>
           <width>70</width>
           <height>20</height>
          </size>
         </property>
         <property name="maximumSize">
          <size>
           <width>16777215</width>
           <height>20</height>
          </size>
         </property>
         <property name="toolTip">
          <string>Minimum gap (frames) between generated shots.
In Auto-Detect mode, clusters animation by this gap.
In All Keys / Skip Zero mode, merges keys within this distance.
Unused in Zero = Shot End mode.</string>
         </property>
         <property name="prefix">
          <string>Min Gap:	</string>
         </property>
         <property name="decimals">
          <number>1</number>
         </property>
         <property name="minimum">
          <double>0.100000000000000</double>
         </property>
         <property name="maximum">
          <double>1000.000000000000000</double>
         </property>
         <property name="value">
          <double>5.000000000000000</double>
         </property>
        </widget>
       </item>
