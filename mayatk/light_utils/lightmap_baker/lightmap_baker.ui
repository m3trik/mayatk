        </property>
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Bake a lightmap per selected object and wire it up: pack lightmap UVs, Arnold-bake albedo × lighting into one HDR map, dilate seams, then make the lightmap UV0 and assign an unlit material. The result previews baked and exports to Unity as-is (stock Unlit shader). Non-destructive — Revert to Source from the header menu.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
