      <item>
       <widget class="Header" name="header">
        <property name="minimumSize">
         <size>
          <width>0</width>
          <height>19</height>
         </size>
        </property>
        <property name="maximumSize">
         <size>
          <width>999</width>
          <height>19</height>
         </size>
        </property>
        <property name="font">
         <font>
          <weight>75</weight>
          <bold>true</bold>
         </font>
        </property>
        <property name="text">
         <string>LIGHTMAP BAKER</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="ComboBox" name="cmb_scope">
        <property name="minimumSize">
         <size>
          <width>180</width>
          <height>19</height>
         </size>
        </property>
        <property name="maximumSize">
         <size>
          <width>999</width>
          <height>19</height>
         </size>
        </property>
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;b&gt;Scope&lt;/b&gt; — which objects Bake Lightmaps acts on.&lt;/p&gt;&lt;p&gt;&lt;b&gt;Selected&lt;/b&gt; (default) — the current selection.&lt;/p&gt;&lt;p&gt;&lt;b&gt;Visible&lt;/b&gt; — every visible mesh in the scene.&lt;/p&gt;&lt;p&gt;&lt;b&gt;Scene&lt;/b&gt; — every mesh in the scene, hidden or not.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="frame">
         <bool>false</bool>
        </property>
       </widget>
      </item>
      <item>
       <widget class="ComboBox" name="cmb001">
        <property name="minimumSize">
         <size>
          <width>180</width>
          <height>19</height>
         </size>
        </property>
        <property name="maximumSize">
         <size>
          <width>999</width>
          <height>19</height>
         </size>
        </property>
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;b&gt;Bake level.&lt;/b&gt;&lt;/p&gt;&lt;p&gt;&lt;b&gt;Lighting Only&lt;/b&gt; (default) — real lightmapping. Bakes lighting onto a 2nd UV channel and &lt;b&gt;keeps&lt;/b&gt; the full PBR material (albedo / normal / metallic). The lightmap is a &lt;b&gt;separate texture&lt;/b&gt; in sourceimages; the engine multiplies albedo × lightmap at runtime and your normal map still works. Self-contained export — UV2 samples the map directly in any engine; a one-file Unity editor helper (optional) auto-binds Unity's native lightmap slots from the FBX. Use this for normal assets.&lt;/p&gt;&lt;p&gt;&lt;b&gt;Fused Unlit&lt;/b&gt; — &lt;b&gt;NOT a lightmap&lt;/b&gt;. Flattens albedo × lighting into one unlit texture; normal / metallic / roughness are &lt;b&gt;discarded&lt;/b&gt; and it can't be re-lit. Only for things you mean to flatten forever (skybox, far LOD, lowest-end mobile prop). If your asset has a normal map to keep, use Lighting Only.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="frame">
         <bool>false</bool>
        </property>
       </widget>
      </item>
      <item>
       <widget class="ComboBox" name="cmb002">
        <property name="minimumSize">
         <size>
          <width>180</width>
          <height>19</height>
         </size>
        </property>
        <property name="maximumSize">
         <size>
          <width>999</width>
          <height>19</height>
         </size>
        </property>
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;b&gt;Packing&lt;/b&gt; (Lighting Only mode only).&lt;/p&gt;&lt;p&gt;&lt;b&gt;Per-Object&lt;/b&gt; (default) — one lightmap texture per object at the full Resolution. Best per-object detail; right for hero assets or small selections.&lt;/p&gt;&lt;p&gt;&lt;b&gt;Atlas by Material&lt;/b&gt; — objects sharing a primary material are consolidated into &lt;b&gt;one shared EXR&lt;/b&gt; (Resolution becomes the shared atlas size), and each object's lightmap UVs are repacked into its area-weighted atlas rect — so the atlas is sampled directly through UV2 with &lt;b&gt;no engine-side setup&lt;/b&gt;, in any engine. Fewer textures, no naming collisions, more efficient texel use for many small objects. Bake-full-then-pack, so the bake quality is unchanged; Revert restores the UVs.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="frame">
         <bool>false</bool>
        </property>
       </widget>
      </item>
