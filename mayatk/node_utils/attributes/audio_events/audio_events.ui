         <property name="toolTip">
          <string>Browse for audio files to add or replace tracks.
File stems become event trigger names.
Re-adding a file with the same name overwrites it
at the same enum index — keyframes are preserved.
If events are already keyed, a sync is triggered
automatically to rebuild the composite WAV.
Creates an audio_events locator if nothing is selected.</string>
         </property>
         <property name="text">
          <string>Add</string>
         </property>
        </widget>
